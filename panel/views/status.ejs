<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1>Network Status</h1>
    <p>Live node health, uptime markers, downtime markers, locations, latency, and server counts.</p>
  </div>
  <a class="button primary" href="/dashboard">Back to panel</a>
</section>

<section class="grid">
  <div class="card"><h2>Nodes online</h2><div class="stat"><strong><%= nodes.filter(n => n.status === 'up').length %>/<%= nodes.length %></strong><span>Healthy</span></div></div>
  <div class="card"><h2>Total servers</h2><div class="stat"><strong><%= servers.length %></strong><span>Tracked</span></div></div>
  <div class="card"><h2>Locations</h2><div class="stat"><strong><%= [...new Set(nodes.map(n => n.location || 'Unknown'))].length %></strong><span>Regions</span></div></div>
</section>

<section class="card mt-12">
  <h2>Nodes</h2>
  <table>
    <thead><tr><th>Status</th><th>Node</th><th>Location</th><th>Latency</th><th>Servers</th><th>Uptime / downtime</th></tr></thead>
    <tbody>
      <% nodes.forEach(n => { %>
        <tr>
          <td><span class="pill <%= n.status === 'up' ? 'success' : 'danger' %>"><%= n.status === 'up' ? 'Online' : 'Offline' %></span></td>
          <td><strong><%= n.name %></strong></td>
          <td><%= n.location || 'Unknown' %></td>
          <td><%= n.latencyMs !== null ? n.latencyMs + 'ms' : '-' %></td>
          <td><%= n.servers %></td>
          <td class="small">
            <div class="uptime-container">
              <div class="uptime-indicator <%= n.status === 'up' ? 'online' : 'offline' %>">
                <div class="uptime-pulse"></div>
              </div>
              <div class="uptime-info">
                <span class="uptime-status <%= n.status === 'up' ? 'online' : 'offline' %>"><%= n.status === 'up' ? '● Online' : '● Offline' %></span>
                <span class="uptime-time">Last online: <%= n.lastOnlineAt ? new Date(n.lastOnlineAt).toLocaleString() : 'Never' %></span>
                <span class="uptime-time">Last down: <%= n.lastDownAt ? new Date(n.lastDownAt).toLocaleString() : 'Never' %></span>
                <% if (n.error) { %><span class="uptime-error"><%= n.error %></span><% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<style>
.uptime-container {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
}
.uptime-indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  position: relative;
}
.uptime-indicator.online {
  background: #28a745;
  box-shadow: 0 0 8px rgba(40, 167, 69, 0.6);
}
.uptime-indicator.offline {
  background: #dc3545;
  box-shadow: 0 0 8px rgba(220, 53, 69, 0.6);
}
.uptime-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
  border-radius: 50%;
  animation: pulse 2s infinite;
}
.uptime-indicator.online .uptime-pulse {
  background: rgba(40, 167, 69, 0.4);
}
.uptime-indicator.offline .uptime-pulse {
  background: rgba(220, 53, 69, 0.4);
}
@keyframes pulse {
  0% {
    width: 100%;
    height: 100%;
    opacity: 1;
  }
  100% {
    width: 200%;
    height: 200%;
    opacity: 0;
  }
}
.uptime-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.uptime-status {
  font-weight: 600;
  font-size: 13px;
}
.uptime-status.online {
  color: #28a745;
}
.uptime-status.offline {
  color: #dc3545;
}
.uptime-time {
  font-size: 11px;
  color: #666;
}
.uptime-error {
  font-size: 11px;
  color: #dc3545;
  margin-top: 2px;
}
</style>
<%- include('layout-bottom') %>
