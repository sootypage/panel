<%- include('layout-top', { title }) %>
<section class="card narrow">
  <h1>Forgot Password</h1>
  <p class="muted">Enter your email address and we'll send you a link to reset your password.</p>
  <form method="post" action="/forgot-password" class="form">
    <label>Email</label>
    <input name="email" type="email" required placeholder="your@email.com">
    <button class="primary">Send Reset Link</button>
  </form>
  <p class="muted small"><a href="/login">Back to login</a></p>
</section>
<%- include('layout-bottom') %>
