<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1>Admin</h1>
    <p>Manage nodes, users, servers, plans, API keys, and website provisioning.</p>
  </div>
</section>

<section class="tab-bar card">
  <button class="tab-btn active" data-tab="overview">Overview</button>
  <button class="tab-btn" data-tab="nodes">Nodes</button>
  <button class="tab-btn" data-tab="users">Users</button>
  <button class="tab-btn" data-tab="servers">Create server</button>
  <button class="tab-btn" data-tab="resources">Server resources</button>
  <button class="tab-btn" data-tab="import">Import Docker</button>
  <button class="tab-btn" data-tab="plans">Plans</button>
  <button class="tab-btn" data-tab="api">API / Website</button>
  <button class="tab-btn" data-tab="security">Security</button>
</section>

<section id="tab-overview" class="tab-panel active">
  <div class="grid">
    <div class="card"><h2>Users</h2><div class="stat"><strong><%= db.users.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>Nodes</h2><div class="stat"><strong><%= db.nodes.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>Servers</h2><div class="stat"><strong><%= db.servers.length %></strong><span>Total</span></div></div>
    <div class="card"><h2>API keys</h2><div class="stat"><strong><%= (db.apiKeys || []).filter(k => !k.revokedAt).length %></strong><span>Active</span></div></div>
  </div>
</section>

<section id="tab-nodes" class="tab-panel">
  <div class="card">
    <h2>Add Ubuntu node</h2>
    <form method="post" action="/admin/nodes" class="form two-col">
      <label>Name</label><input name="name" required placeholder="Sydney Node 1">
      <label>Agent URL</label><input name="url" required placeholder="http://1.2.3.4:4100">
      <label>Public IP</label><input name="publicIp" placeholder="38.87.117.169">
      <label>Agent token</label><input name="token" placeholder="Paste agent token if different from panel token">
      <label>Location</label><input name="location" placeholder="Australia">
      <button class="primary span">Add node</button>
    </form>
  </div>
  <div class="card">
    <h2>Nodes</h2>
    <table><thead><tr><th>Name</th><th>URL</th><th>Public IP</th><th>Location</th><th>Status data</th><th>Actions</th></tr></thead><tbody>
      <% db.nodes.forEach(n => { %>
        <tr>
          <form method="post" action="/admin/nodes/<%= n.id %>/update">
            <td><input name="name" value="<%= n.name %>"></td>
            <td><input name="url" value="<%= n.url %>"></td>
            <td><input name="publicIp" value="<%= n.publicIp || '' %>"></td>
            <td><input name="location" value="<%= n.location || 'Unknown' %>"></td>
            <td class="small">Last online: <%= n.lastOnlineAt ? new Date(n.lastOnlineAt).toLocaleString() : 'Never' %><br>Last down: <%= n.lastDownAt ? new Date(n.lastDownAt).toLocaleString() : 'Never' %></td>
            <td class="actions-cell"><input name="token" type="password" placeholder="New token optional"><button class="small-btn">Save</button>
          </form>
          <form method="post" action="/admin/nodes/<%= n.id %>/delete" onsubmit="return confirm('Remove this node? You must move/delete servers first.')"><button class="danger small-btn">Remove</button></form></td>
        </tr>
      <% }) %>
    </tbody></table>
    <p class="muted small"><a href="/status">Open public status page</a> to see uptime, downtime, location, latency, and servers per node.</p>
  </div>
</section>

<section id="tab-users" class="tab-panel">
  <div class="card">
    <h2>Create user</h2>
    <form method="post" action="/admin/users" class="form two-col">
      <label>Name</label><input name="name" placeholder="User name">
      <label>Email</label><input name="email" type="email" required>
      <label>Password</label><input name="password" type="text" required>
      <label>Role</label><select name="role"><option value="user">User</option><option value="admin">Admin</option></select>
      <label>Subdomain slots</label><input name="subdomainSlots" type="number" value="1" min="0">
      <label>Extra port slots</label><input name="portSlots" type="number" value="0" min="0">
      <label>Backup slots</label><input name="backupSlots" type="number" value="1" min="0">
      <label>Database slots</label><input name="databaseSlots" type="number" value="0" min="0">
      <button class="primary span">Create user</button>
    </form>
  </div>
  <div class="card">
    <h2>Users</h2>
    <table><thead><tr><th>Email</th><th>Name</th><th>Role</th><th>Subdomain slots</th><th>Port slots</th><th>Backup slots</th><th>Database slots</th><th>Actions</th></tr></thead><tbody>
      <% db.users.forEach(u => { %>
        <tr>
          <td><%= u.email %></td><td><%= u.name %></td><td><%= u.role %></td>
          <td><%= u.subdomainSlots || (u.role === 'admin' ? 999 : 1) %></td>
          <td><%= u.portSlots || (u.role === 'admin' ? 999 : 0) %></td>
          <td><%= u.backupSlots || (u.role === 'admin' ? 999 : 1) %></td>
          <td><%= u.databaseSlots || (u.role === 'admin' ? 999 : 0) %></td>
          <td>
            <form method="post" action="/admin/users/<%= u.id %>/resources" class="inline-form-wide">
              <input name="subdomainSlots" type="number" min="0" value="<%= u.subdomainSlots || (u.role === 'admin' ? 999 : 1) %>" title="Subdomain slots">
              <input name="portSlots" type="number" min="0" value="<%= u.portSlots || (u.role === 'admin' ? 999 : 0) %>" title="Extra port slots">
              <input name="backupSlots" type="number" min="0" value="<%= u.backupSlots || (u.role === 'admin' ? 999 : 1) %>" title="Backup slots">
              <input name="databaseSlots" type="number" min="0" value="<%= u.databaseSlots || (u.role === 'admin' ? 999 : 0) %>" title="Database slots">
              <button class="small-btn">Save slots</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-servers" class="tab-panel">
  <div class="card">
    <h2>Create game server</h2>
    <form method="post" action="/admin/servers" class="form two-col">
      <label>Server name</label><input name="name" required placeholder="survival-1">
      <label>Owner</label><select name="ownerId" required><% db.users.forEach(u => { %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select>
      <label>Node</label><select name="nodeId" required><% db.nodes.forEach(n => { %><option value="<%= n.id %>"><%= n.name %> - <%= n.url %></option><% }) %></select>
      <label>Server type</label>
      <select name="serverType" id="serverTypeSelect">
        <% (serverTemplates || []).forEach(t => { %>
          <option value="<%= t.key %>" data-game="<%= t.game %>" data-image="<%= t.image %>" data-port="<%= t.defaultPort %>" data-ram="<%= t.defaultMemoryMb %>" data-storage="<%= t.defaultStorageMb %>" data-addons="<%= t.addons %>"><%= t.label %> — <%= t.category %></option>
        <% }) %>
      </select>
      <div></div><p class="muted small" id="serverTypeHint">Pick a template and the panel will fill the image, port, RAM, storage, and add-on type.</p>
      <label>Game key</label><input name="game" id="gameInput" placeholder="Leave blank to auto set from type">
      <label>Docker image</label><input name="image" id="imageInput" placeholder="Leave blank to auto set from type">
      <label>Minecraft / game version</label><input name="version" value="LATEST">
      <label>Memory limit MB</label><input name="memoryMb" id="memoryInput" type="number" value="2048">
      <label>CPU limit</label><input name="cpuLimit" type="number" step="0.25" value="1">
      <label>Storage limit MB</label><input name="storageLimitMb" id="storageInput" type="number" value="10240">
      <label>Storage location</label><select name="storageLocation"><option value="/mnt/ssd1">SSD 1 (/mnt/ssd1)</option><option value="/mnt/ssd2">SSD 2 (/mnt/ssd2)</option><option value="/var/lib/docker">Default (/var/lib/docker)</option></select>
      <label>Server IP</label><input name="ipAddress" placeholder="Leave blank to use node public IP">
      <label>Public port</label><input name="port" id="portInput" type="number" value="25565">
      <button class="primary span">Create server</button>
    </form>
  </div>
</section>


<section id="tab-resources" class="tab-panel">
  <div class="card">
    <h2>Edit server resources</h2>
    <p class="muted">Changing RAM/CPU/port recreates the Docker container but keeps the same /data files.</p>
    <table><thead><tr><th>Server</th><th>Owner</th><th>RAM MB</th><th>CPU</th><th>Storage MB</th><th>Port</th><th>Save</th></tr></thead><tbody>
      <% db.servers.forEach(s => { const owner = db.users.find(u => u.id === s.ownerId); %>
        <tr>
          <td><%= s.name %></td>
          <td><%= owner ? owner.email : s.ownerId %></td>
          <form method="post" action="/admin/servers/<%= s.id %>/resources">
            <td><input name="memoryMb" type="number" value="<%= s.memoryMb || 2048 %>"></td>
            <td><input name="cpuLimit" type="number" step="0.25" value="<%= s.cpuLimit || 1 %>"></td>
            <td><input name="storageLimitMb" type="number" value="<%= s.storageLimitMb || 10240 %>"></td>
            <td><input name="port" type="number" value="<%= s.port || 25565 %>"></td>
            <td><button class="small-btn">Save</button></td>
          </form>
        </tr>
      <% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-import" class="tab-panel">
  <div class="card">
    <h2>Import existing Docker container</h2>
    <p class="muted">Import old Docker servers into the panel without deleting their files. The importer now scans ports, mounts, image, environment, and can show containers from the selected node.</p>
    <div class="notice-card">
      <strong>Step 1:</strong> select a node and click scan. <strong>Step 2:</strong> copy a container name into the import form. <strong>Step 3:</strong> choose owner/resources and import.
    </div>
    <div class="button-row mt-12">
      <select id="importScanNode"><% db.nodes.forEach(n => { %><option value="<%= n.id %>"><%= n.name %> - <%= n.location || 'Unknown' %></option><% }) %></select>
      <button type="button" class="primary" id="scanDockerBtn">Scan node containers</button>
    </div>
    <div id="dockerScanResults" class="docker-scan-results muted small mt-12">No scan yet.</div>
    <hr class="soft-sep">
    <form method="post" action="/admin/import-docker" class="form two-col">
      <label>Node</label><select name="nodeId" id="importNodeSelect"><% db.nodes.forEach(n => { %><option value="<%= n.id %>"><%= n.name %> - <%= n.url %></option><% }) %></select>
      <label>Owner</label><select name="ownerId"><% db.users.forEach(u => { %><option value="<%= u.id %>"><%= u.email %></option><% }) %></select>
      <label>Container name or ID</label><input name="container" id="importContainerInput" required placeholder="amp-warsmp-xxxx or c85336af2695">
      <label>Panel server name</label><input name="name" id="importNameInput" required placeholder="warsmp">
      <label>Server type</label><select name="serverType"><% (serverTemplates || []).forEach(t => { %><option value="<%= t.key %>"><%= t.label %></option><% }) %></select>
      <label>Game key</label><input name="game" placeholder="Auto-detected if blank">
      <label>Docker image</label><input name="image" placeholder="Keep existing image if blank">
      <label>Version</label><input name="version" placeholder="Auto-detected / LATEST">
      <label>Public IP</label><input name="ipAddress" placeholder="Leave blank to use node public IP">
      <label>Main public port</label><input name="port" type="number" placeholder="Auto-detects first useful port">
      <label>RAM MB</label><input name="memoryMb" type="number" value="2048">
      <label>CPU</label><input name="cpuLimit" type="number" step="0.25" value="1">
      <label>Storage MB</label><input name="storageLimitMb" type="number" value="10240">
      <label>Storage location</label><select name="storageLocation"><option value="/mnt/ssd1">SSD 1 (/mnt/ssd1)</option><option value="/mnt/ssd2">SSD 2 (/mnt/ssd2)</option><option value="/var/lib/docker">Default (/var/lib/docker)</option></select>
      <label>Managed recreate</label><label class="check-card"><input name="recreateManaged" type="checkbox"> <span>Recreate container with panel limits and same data mount after import</span><small>Leave off to only link the existing container.</small></label>
      <button class="primary span">Import container</button>
    </form>
  </div>
</section>

<section id="tab-plans" class="tab-panel">
  <div class="card">
    <h2>Billing Plans</h2>
    <p class="muted">Create subscription plans for Stripe billing. Users can subscribe from the billing page.</p>
    <form method="post" action="/admin/plans" class="form two-col">
      <label>Plan name</label><input name="name" placeholder="Minecraft 4GB">
      <label>Price</label><input name="price" type="number" step="0.01" placeholder="9.99">
      <label>Interval</label><select name="interval"><option value="month">Monthly</option><option value="year">Yearly</option></select>
      <label>Currency</label><select name="currency"><option value="usd">USD</option><option value="eur">EUR</option><option value="aud">AUD</option></select>
      <label>Stripe Price ID</label><input name="stripePriceId" placeholder="price_1234567890">
      <label>RAM MB</label><input name="memoryMb" type="number" value="4096">
      <label>CPU</label><input name="cpuLimit" type="number" step="0.25" value="2">
      <label>Storage MB</label><input name="storageLimitMb" type="number" value="20480">
      <button class="primary span">Save plan</button>
    </form>
    <table><thead><tr><th>Name</th><th>Price</th><th>Interval</th><th>RAM</th><th>CPU</th><th>Storage</th><th>Stripe Price ID</th><th>Actions</th></tr></thead><tbody>
      <% (db.plans || []).forEach(p => { %>
        <tr>
          <td><%= p.name %></td>
          <td>$<%= p.price %></td>
          <td><%= p.interval %></td>
          <td><%= p.memoryMb %> MB</td>
          <td><%= p.cpuLimit %></td>
          <td><%= p.storageLimitMb %> MB</td>
          <td><code><%= p.stripePriceId || 'Not set' %></code></td>
          <td>
            <form method="post" action="/admin/plans/<%= p.id %>/delete" onsubmit="return confirm('Delete this plan?');">
              <button type="submit" class="danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-api" class="tab-panel">
  <div class="card">
    <h2>API / Website linking</h2>
    <p class="muted">Create an admin API key with <strong>Website: create users</strong> and <strong>Website: create servers</strong> permissions, then your website can call the provision endpoint after checkout.</p>
    <div class="codebox">POST /api/v1/provision/order<br>Authorization: Bearer YOUR_API_KEY</div>
    <p class="muted small">Example JSON: email, name, serverName, planId, memoryMb, cpuLimit, storageLimitMb, port, serverType, version, orderId. Compatible endpoints: <code>/api/v1/provision/order</code>, <code>/api/provision/order</code>, and <code>/api/admin/provision</code>. Upgrades use <code>/api/v1/provision/upgrade</code> with backupSlots, subdomainSlots, portSlots, databaseSlots, addMemoryMb, addStorageMb, or addCpuLimit.</p>
    <a class="button primary" href="/api-keys">Manage API Keys</a>
  </div>
  <div class="card">
    <h2>Active API keys</h2>
    <table><thead><tr><th>Name</th><th>User</th><th>Permissions</th></tr></thead><tbody>
      <% (db.apiKeys || []).filter(k => !k.revokedAt).forEach(k => { const u = db.users.find(u => u.id === k.userId); %><tr><td><%= k.name %></td><td><%= u ? u.email : k.userId %></td><td><%= (k.permissions || []).join(', ') %></td></tr><% }) %>
    </tbody></table>
  </div>
</section>

<section id="tab-security" class="tab-panel">
  <div class="grid-2">
    <div class="card">
      <h2>Panel security</h2>
      <ul class="installed-list">
        <li><span>Helmet security headers</span><span>Enabled</span></li>
        <li><span>Login rate limit</span><span>20 / 15 min</span></li>
        <li><span>API rate limit</span><span>120 / min</span></li>
        <li><span>Write action rate limit</span><span>60 / min</span></li>
        <li><span>API key storage</span><span>SHA-256 hashed, full key shown once</span></li>
        <li><span>API CORS</span><span>Use API_CORS_ORIGIN=https://your-shop.com in production</span></li>
        <li><span>Secure cookies</span><span>Set COOKIE_SECURE=true when HTTPS proxy is working</span></li>
      </ul>
    </div>
    <div class="card">
      <h2>Node security checklist</h2>
      <ul class="installed-list">
        <li><span>Use a long AGENT_TOKEN</span><span>32+ chars</span></li>
        <li><span>Timing-safe token checks</span><span>Enabled in node code</span></li>
        <li><span>Optional panel IP allowlist</span><span>AGENT_ALLOWED_PANEL_IPS</span></li>
        <li><span>Do not expose port 4100 publicly unless needed</span><span>Use firewall</span></li>
        <li><span>Allow only panel IP to node port</span><span>Recommended</span></li>
        <li><span>Use HTTPS/reverse proxy for panel</span><span>Recommended</span></li>
      </ul>
      <div class="codebox">sudo ufw allow from PANEL_IP to any port 4100 proto tcp</div>
    </div>
  </div>
</section>

<script>
function activateTab(name) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === name));
  document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.toggle('active', panel.id === 'tab-' + name));
  if (history.replaceState) history.replaceState(null, '', '#'+name);
}
document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab)));
activateTab((location.hash || '#overview').replace('#',''));
</script>

<script>
(function(){
  const type = document.getElementById('serverTypeSelect');
  if (type) {
    const apply = () => {
      const o = type.options[type.selectedIndex];
      const setIfBlank = (id, val) => { const el = document.getElementById(id); if (el && (!el.value || el.dataset.autofilled === '1')) { el.value = val || ''; el.dataset.autofilled = '1'; } };
      setIfBlank('gameInput', o.dataset.game);
      setIfBlank('imageInput', o.dataset.image);
      setIfBlank('portInput', o.dataset.port);
      setIfBlank('memoryInput', o.dataset.ram);
      setIfBlank('storageInput', o.dataset.storage);
      const hint = document.getElementById('serverTypeHint');
      if (hint) hint.textContent = `${o.textContent.trim()} uses ${o.dataset.image}, port ${o.dataset.port}, and add-ons: ${o.dataset.addons || 'none'}.`;
    };
    type.addEventListener('change', apply); apply();
  }
  const scan = document.getElementById('scanDockerBtn');
  if (scan) scan.addEventListener('click', async () => {
    const nodeId = document.getElementById('importScanNode').value;
    const out = document.getElementById('dockerScanResults');
    out.textContent = 'Scanning containers...';
    try {
      const r = await fetch(`/admin/import-docker/containers?nodeId=${encodeURIComponent(nodeId)}`);
      const data = await r.json();
      if (!r.ok) throw new Error(data.error || 'Scan failed');
      const rows = (data.containers || []).map(c => `<tr><td><button type="button" class="small-btn pick-container" data-name="${c.name}">Use</button></td><td>${c.name}</td><td>${c.image}</td><td>${c.state || ''}<br>${c.status || ''}</td><td>${(c.ports||[]).map(p => `${p.publicPort}->${p.containerPort}/${p.protocol}`).join('<br>') || 'None'}</td><td>${c.dataPath || 'No /data mount'}</td><td>${c.imported ? 'Already imported' : (c.canImport ? 'Ready' : 'Needs mount')}</td></tr>`).join('');
      out.innerHTML = `<table><thead><tr><th></th><th>Name</th><th>Image</th><th>Status</th><th>Ports</th><th>Data path</th><th>Import</th></tr></thead><tbody>${rows || '<tr><td colspan="7">No containers found.</td></tr>'}</tbody></table>`;
      out.querySelectorAll('.pick-container').forEach(btn => btn.addEventListener('click', () => {
        const containerData = (data.containers || []).find(c => c.name === btn.dataset.name);
        document.getElementById('importContainerInput').value = btn.dataset.name;
        const name = btn.dataset.name.replace(/^amp-/, '').replace(/-[a-f0-9]{8}$/i, '');
        if (!document.getElementById('importNameInput').value) document.getElementById('importNameInput').value = name;
        document.getElementById('importNodeSelect').value = nodeId;
        
        // Auto-detect and fill in container details
        if (containerData) {
          // Auto-fill port from first useful port
          if (containerData.ports && containerData.ports.length > 0) {
            const firstPort = containerData.ports.find(p => p.publicPort && p.publicPort !== 25565) || containerData.ports[0];
            if (firstPort && firstPort.publicPort) {
              document.querySelector('input[name="port"]').value = firstPort.publicPort;
            }
          }
          
          // Auto-fill image
          if (containerData.image && !document.querySelector('input[name="image"]').value) {
            document.querySelector('input[name="image"]').value = containerData.image;
          }
          
          // Auto-detect game type from image
          const imageLower = (containerData.image || '').toLowerCase();
          let detectedType = 'PAPER';
          if (imageLower.includes('minecraft')) detectedType = 'PAPER';
          else if (imageLower.includes('rust')) detectedType = 'RUST';
          else if (imageLower.includes('valheim')) detectedType = 'VALHEIM';
          else if (imageLower.includes('terraria')) detectedType = 'TERRARIA';
          else if (imageLower.includes('factorio')) detectedType = 'FACTORIO';
          else if (imageLower.includes('node')) detectedType = 'NODEJS';
          else if (imageLower.includes('python')) detectedType = 'PYTHON';
          else if (imageLower.includes('mariadb')) detectedType = 'MARIADB';
          else if (imageLower.includes('mysql')) detectedType = 'MYSQL';
          else if (imageLower.includes('postgres')) detectedType = 'POSTGRESQL';
          
          const typeSelect = document.querySelector('select[name="serverType"]');
          if (typeSelect) {
            typeSelect.value = detectedType;
          }
          
          // Auto-fill game key if blank
          if (!document.querySelector('input[name="game"]').value) {
            document.querySelector('input[name="game"]').value = detectedType.toLowerCase();
          }
        }
      }));
    } catch (e) { out.textContent = e.message; }
  });
})();
</script>

<%- include('layout-bottom') %>
