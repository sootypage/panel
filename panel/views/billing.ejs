<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1>Billing</h1>
    <p>View your credit balance, subscriptions, and payment history.</p>
  </div>
  <div class="stat"><strong>$<%= user.creditBalance.toFixed(2) %></strong><span>Credit Balance</span></div>
  <div class="stat"><strong>$<%= user.totalSpent.toFixed(2) %></strong><span>Total Spent</span></div>
</section>

<section class="card">
  <h2>Shop Purchases</h2>
  <% if (shopPurchases.length) { %>
    <table>
      <thead>
        <tr>
          <th>Item</th>
          <th>Server</th>
          <th>Price</th>
          <th>Payment</th>
          <th>Date</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% shopPurchases.forEach(purchase => { %>
          <tr>
            <td><%= purchase.itemName %></td>
            <td><%= purchase.serverName %></td>
            <td>$<%= purchase.price.toFixed(2) %></td>
            <td><%= purchase.paymentMethod === 'credit' ? 'Credit' : 'Card' %></td>
            <td><%= new Date(purchase.createdAt).toLocaleDateString() %></td>
            <td>
              <span class="pill <%= purchase.status === 'active' ? 'success' : purchase.status === 'cancelled' ? 'danger' : 'default' %>"><%= purchase.status %></span>
            </td>
            <td>
              <% if (purchase.status === 'active') { %>
                <form action="/shop/cancel/<%= purchase.id %>" method="POST" onsubmit="return confirm('Cancel this purchase? Server will be deleted.')">
                  <button type="submit" class="danger">Cancel</button>
                </form>
              <% } else { %>
                <span class="muted">-</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="muted">No shop purchases yet. <a href="/shop">Visit the shop</a> to purchase servers.</p>
  <% } %>
</section>

<section class="card">
  <h2>Available Plans</h2>
  <div class="plans-grid">
    <% (db.plans || []).forEach(plan => { %>
      <div class="plan-card">
        <h3><%= plan.name %></h3>
        <div class="plan-price">$<%= plan.price %>/<%= plan.interval %></div>
        <ul class="plan-features">
          <li><%= plan.memoryMb %> MB RAM</li>
          <li><%= plan.cpuLimit %> CPU</li>
          <li><%= plan.storageLimitMb %> MB Storage</li>
        </ul>
        <form action="/billing/subscribe" method="POST">
          <input type="hidden" name="planId" value="<%= plan.id %>">
          <label>Server Name</label><input name="serverName" placeholder="My Server" required>
          <label>Server Type</label><select name="serverType">
            <option value="PAPER">Minecraft Paper</option>
            <option value="PURPUR">Minecraft Purpur</option>
            <option value="SPIGOT">Minecraft Spigot</option>
            <option value="VANILLA">Minecraft Vanilla</option>
            <option value="FABRIC">Minecraft Fabric</option>
            <option value="FORGE">Minecraft Forge</option>
            <option value="RUST">Rust</option>
            <option value="VALHEIM">Valheim</option>
            <option value="TERRARIA">Terraria</option>
            <option value="FACTORIO">Factorio</option>
          </select>
          <button type="submit" class="primary">Subscribe</button>
        </form>
      </div>
    <% }) %>
    <% if (!(db.plans || []).length) { %>
      <p class="muted">No plans available. Contact admin to set up plans.</p>
    <% } %>
  </div>
</section>

<section class="card">
  <h2>Your Subscriptions</h2>
  <% if (subscriptions.length) { %>
    <table>
      <thead>
        <tr>
          <th>Plan</th>
          <th>Price</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% subscriptions.forEach(sub => { %>
          <tr>
            <td><%= sub.planName %></td>
            <td>$<%= sub.price %>/<%= sub.interval %></td>
            <td>
              <span class="pill <%= sub.status === 'active' ? 'success' : 'danger' %>"><%= sub.status %></span>
            </td>
            <td><%= new Date(sub.createdAt).toLocaleDateString() %></td>
            <td>
              <% if (sub.status === 'active') { %>
                <form action="/billing/cancel/<%= sub.id %>" method="POST" onsubmit="return confirm('Are you sure you want to cancel this subscription?');">
                  <button type="submit" class="danger">Cancel</button>
                </form>
              <% } else { %>
                <span class="muted">-</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="muted">No active subscriptions.</p>
  <% } %>
</section>

<section class="card">
  <h2>Payment History</h2>
  <% if (payments.length) { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Invoice ID</th>
        </tr>
      </thead>
      <tbody>
        <% payments.forEach(payment => { %>
          <tr>
            <td><%= new Date(payment.createdAt).toLocaleString() %></td>
            <td>$<%= payment.amount %> <%= payment.currency.toUpperCase() %></td>
            <td>
              <span class="pill <%= payment.status === 'succeeded' ? 'success' : 'danger' %>"><%= payment.status %></span>
            </td>
            <td><code><%= payment.stripeInvoiceId %></code></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="muted">No payment history.</p>
  <% } %>
</section>

<style>
.plans-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
  margin-top: 1rem;
}
.plan-card {
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 1.5rem;
  text-align: center;
}
.plan-card h3 {
  margin: 0 0 0.5rem 0;
}
.plan-price {
  font-size: 2rem;
  font-weight: bold;
  margin: 1rem 0;
}
.plan-features {
  list-style: none;
  padding: 0;
  margin: 1rem 0;
  text-align: left;
}
.plan-features li {
  padding: 0.25rem 0;
}
</style>
<%- include('layout-bottom') %>
