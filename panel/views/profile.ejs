<%- include('layout-top', { title }) %>
<section class="hero">
  <div>
    <h1>Profile</h1>
    <p>Manage your account settings.</p>
  </div>
  <div class="profile-avatar">
    <% if (user.avatar) { %>
      <img src="<%= user.avatar %>" alt="Profile Picture">
    <% } else { %>
      <div class="avatar-placeholder"><%= user.name.charAt(0).toUpperCase() %></div>
    <% } %>
  </div>
</section>

<section class="card">
  <h2>Profile Picture</h2>
  <form method="post" action="/profile/avatar" enctype="multipart/form-data" class="form">
    <label>Upload Image</label>
    <input name="avatar" type="file" accept="image/*">
    <button type="submit" class="primary">Upload</button>
  </form>
  <% if (user.avatar) { %>
    <form method="post" action="/profile/avatar/remove" class="inline">
      <button type="submit" class="danger">Remove Picture</button>
    </form>
  <% } %>
</section>

<section class="card">
  <h2>Account Information</h2>
  <form method="post" action="/profile/email" class="form">
    <label>Email</label>
    <input name="email" type="email" required value="<%= user.email %>">
    <label>Current Password</label>
    <input name="currentPassword" type="password" required placeholder="Enter your current password">
    <button type="submit" class="primary">Update Email</button>
  </form>
</section>

<section class="card">
  <h2>Change Password</h2>
  <form method="post" action="/profile/password" class="form">
    <label>Current Password</label>
    <input name="currentPassword" type="password" required placeholder="Enter your current password">
    <label>New Password</label>
    <input name="newPassword" type="password" required placeholder="••••••••" minlength="8">
    <label>Confirm New Password</label>
    <input name="confirmPassword" type="password" required placeholder="••••••••" minlength="8">
    <button type="submit" class="primary">Change Password</button>
  </form>
</section>

<section class="card">
  <h2>Account Details</h2>
  <table>
    <tr><th>Name</th><td><%= user.name %></td></tr>
    <tr><th>Email</th><td><%= user.email %></td></tr>
    <tr><th>Role</th><td><%= user.role %></td></tr>
    <tr><th>Credit Balance</th><td>$<%= user.creditBalance.toFixed(2) %></td></tr>
    <tr><th>Total Spent</th><td>$<%= user.totalSpent.toFixed(2) %></td></tr>
    <tr><th>Member Since</th><td><%= new Date(user.createdAt).toLocaleDateString() %></td></tr>
  </table>
</section>

<style>
.profile-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ddd;
}
.profile-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: bold;
  color: #666;
  background: #f0f0f0;
}
</style>
<%- include('layout-bottom') %>
