<%- include('layout-top', { title }) %>
<section class="card narrow">
  <h1>Reset Password</h1>
  <p class="muted">Enter your new password below.</p>
  <form method="post" action="/reset-password" class="form">
    <input type="hidden" name="token" value="<%= token %>">
    <label>New Password</label>
    <input name="password" type="password" required placeholder="••••••••" minlength="8">
    <label>Confirm Password</label>
    <input name="confirmPassword" type="password" required placeholder="••••••••" minlength="8">
    <button class="primary">Reset Password</button>
  </form>
  <p class="muted small"><a href="/login">Back to login</a></p>
</section>
<%- include('layout-bottom') %>
