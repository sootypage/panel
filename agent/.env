# ================================
# Custom AMP Panel v4 - AGENT/NODE .env
# Put this file next to agent.js
# ================================

PORT=4100
AGENT_NAME=Main Node
AGENT_LOCATION=Australia

# Must match PANEL_TO_AGENT_TOKEN in the panel .env
AGENT_TOKEN=hferhfer88u934q8yu84hf4884jjf4944

# Security
# Leave blank while testing.
# Later, set this to your panel server IP only.
# Example: AGENT_ALLOWED_PANEL_IPS=1.2.3.4
AGENT_ALLOWED_PANEL_IPS=

MAX_AGENT_BODY_SIZE=20mb

# Node folders
SERVERS_DIR=/opt/custom-amp/servers
BACKUPS_DIR=/opt/custom-amp/backups
TMP_DIR=/opt/custom-amp/tmp

# Console/SFTP
MAX_CONSOLE_LINES=5000
SFTP_PORT=2222
SFTP_CONTAINER_NAME=custom-amp-sftp

# Resource auto-stop settings
RESOURCE_MONITOR_INTERVAL_MS=20000
RESOURCE_STOP_MEMORY_PERCENT=99
RESOURCE_STOP_CPU_PERCENT=98
