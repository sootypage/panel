# ================================
# Custom AMP Panel v4 - PANEL .env
# Put this file next to server.js
# ================================

# Panel web server
PORT=3000
BRAND_NAME=Custom AMP Panel
DATA_DIR=./data
NODE_API_TIMEOUT_MS=10000
MAX_BODY_SIZE=20mb
TRUST_PROXY=1

# Public URLs
# Change these to your real panel and shop domains
PUBLIC_BASE_URL=https://your-panel-domain.com
PANEL_LOGIN_URL=https://your-panel-domain.com/login
UPGRADE_WEBSITE_URL=https://your-shop-domain.com/upgrades

# Login/session
# Keep false on Wispbyte if login sends you back to /login
COOKIE_SECURE=false
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# Admin account
ADMIN_EMAIL=dylanpage081@gmail.com
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
RESET_ADMIN_ON_START=true

# Database
# Leave this disabled on Wispbyte if you see: spawnSync psql ENOENT
# The panel will use data/db.json instead.
# DATABASE_URL=postgresql://custom_amp:CHANGE_PASSWORD@127.0.0.1:5432/custom_amp_panel

# Panel to Agent/Node auth
# This MUST match AGENT_TOKEN in the agent .env
PANEL_TO_AGENT_TOKEN=CHANGE_THIS_TO_A_LONG_SHARED_NODE_TOKEN

# Website API / CORS
# For testing use *
# For production use your shop domain only, example:
# API_CORS_ORIGIN=https://your-shop-domain.com
API_CORS_ORIGIN=*

# Cloudflare subdomains, optional
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ROOT_DOMAIN=
CLOUDFLARE_PROXIED=false

# Stripe, optional
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Discord webhook, optional
DISCORD_WEBHOOK_URL=
